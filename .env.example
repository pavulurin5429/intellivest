# LLM - Groq (free at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Vector Store - Pinecone (free at pinecone.io)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=investment-intel

# Database - Supabase (free at supabase.com)
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Market Data - Alpaca (free paper trading at alpaca.markets)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# News - optional (rss feeds work without this)
NEWS_API_KEY=your_newsapi_key_here

# App Config
ENVIRONMENT=development
LOG_LEVEL=INFO
